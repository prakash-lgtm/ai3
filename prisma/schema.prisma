generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  username  String?
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  threads   Thread[]
}

model Thread {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  title     String?
  model     String?
  userId    String?   // Link to user, optional for anonymous sessions
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  role      String
  content   String
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
